# Configuración de IA (OpenRouter)
OPENROUTER_API_KEY=tu_clave_aqui
OPENROUTER_ENABLED=true
OPENROUTER_DISCOVER_FREE_MODEL=true
AI_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free

# Configuración Oracle
# Ruta al Oracle Instant Client (necesario en Windows si no está en el PATH)
# Ejemplo: ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_19_8
ORACLE_CLIENT_LIB_DIR=

# Perfil por defecto (debe existir en Cadena_conexions.txt)
DEFAULT_PROFILE=DESENVOLUPAMENT

# Otros
LOG_LEVEL=INFO
